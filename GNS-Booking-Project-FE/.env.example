# Vite: copy to `.env.local` (or `.env`) and restart `npm run dev`.
# Only variables prefixed with VITE_ are exposed to the browser.

# Spring Boot base URL (no trailing slash). Include `/api` if your controllers are under /api.
VITE_API_URL=http://localhost:9090

# Optional — UPI (defaults exist in src/data/paymentConfig.ts)
# VITE_UPI_ID=yourvpa@paytm
# VITE_UPI_PAYEE_NAME=Your name
# VITE_UPI_QR_IMAGE=/upi-paytm-qr.png

# Optional — admin tickets static demo
# VITE_ADMIN_BOOKINGS_STATIC=true
